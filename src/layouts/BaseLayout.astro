---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import '../styles/goofy.css';
import Visualization from '../components/islands/Visualization';
import ThemeToggle from '../components/ThemeToggle.astro';
import PostHog from '../components/posthog.astro';

interface Props {
  title?: string;
  description?: string;
  isHome?: boolean;
}

const {
  title = 'Simon Bukin',
  description = 'Design engineer building quality user experiences.',
  isHome = false
} = Astro.props;

const pathname = Astro.url.pathname;

const navLinks = [
  { name: 'Writing', href: '/writing' },
  { name: 'Work', href: '/portfolio' },
  { name: 'Now', href: '/now' },
  { name: 'About', href: '/about' },
];

const socialLinks = [
  { name: 'GitHub', url: 'https://github.com/simonbukin', icon: 'github' },
  { name: 'LinkedIn', url: 'https://linkedin.com/in/simonbukin', icon: 'linkedin' },
  { name: 'Last.fm', url: 'https://last.fm/user/sbukin_', icon: 'music' },
];

---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/face.svg" />
    <link rel="preload" as="font" href="/fonts/SpaceGrotesk-Variable.woff2" type="font/woff2" crossorigin />
    <link rel="preload" as="font" href="/fonts/JetBrainsMono-Variable.woff2" type="font/woff2" crossorigin />
    <link rel="canonical" href={Astro.url} />
    <title>{title}</title>

    <!-- Theme flash prevention - runs before CSS loads -->
    <script is:inline>
      // Apply theme immediately on initial load
      (function() {
        var theme = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();

      // For Astro View Transitions: set theme on the NEW document BEFORE swap
      // This prevents flash by ensuring incoming page already has correct theme
      document.addEventListener('astro:before-swap', function(e) {
        var theme = localStorage.getItem('theme') || 'dark';
        e.newDocument.documentElement.setAttribute('data-theme', theme);
      });
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:site_name" content="Simon Bukin" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <ClientRouter fallback="animate" />
    <PostHog />
  </head>
  <body class="min-h-screen flex flex-col">
    <div transition:persist="visualization" class="hidden lg:block">
      <Visualization client:only="react" />
    </div>

    <!-- Right side overlays (desktop only) -->
    <div class="hidden lg:block fixed top-0 right-0 w-1/2 h-full pointer-events-none z-10">
      <!-- Theme toggle: top-right -->
      <div class="absolute top-6 right-6 pointer-events-auto">
        <ThemeToggle />
      </div>
    </div>
    {!isHome && (
      <header>
        <nav class="max-w-2xl px-6 py-6">
          <a
            href="/"
            class="inline-flex items-center gap-2 text-lg font-semibold transition-colors"
            style="color: var(--text-secondary);"
          >
            Simon Bukin
            <svg class="w-5 h-5 hover:animate-spin" viewBox="0 0 57 38" fill="none">
              <path d="M22.4338 1.94916C22.5821 0.762795 28.4777 1.02453 29.4199 1.02453C30.8261 1.02453 32.209 1.2067 33.5807 1.25569C35.7201 1.3321 37.7237 2.18404 39.7706 2.41147C40.7369 2.51884 41.6712 3.61861 42.3133 4.26073C43.2034 5.15084 44.1934 5.90965 45.0872 6.80346C45.8972 7.61346 46.5449 8.34247 47.1676 9.29481C47.8281 10.3049 48.0218 11.6837 48.7857 12.5824C49.5074 13.4314 49.68 15.0452 49.9929 16.1011C50.349 17.3031 50.635 18.9671 50.635 20.2106C50.635 22.5316 51.281 24.6828 50.224 26.9141C49.1907 29.0956 47.7491 31.5867 45.5495 32.7444C44.3936 33.3528 43.6605 34.3449 42.3647 34.8248C40.7497 35.423 39.246 35.875 37.5618 36.276C33.7373 37.1865 29.7014 36.8539 25.7856 36.8539C21.7519 36.8539 17.2543 36.3386 13.4572 34.9147C10.2624 33.7166 7.3105 31.3917 6.25285 27.9543C5.41314 25.2253 5.33226 22.5188 6.02169 19.7611C7.21304 14.9957 12.1378 11.4044 16.5265 9.8085C17.4563 9.47038 18.7006 9.23704 19.5444 8.76829C20.2658 8.36751 21.7055 7.72808 22.5494 7.72808C24.1834 7.72808 25.8904 6.5723 27.5193 6.5723M20.5846 17.6675C20.8867 17.6675 20.9246 17.6808 21.0469 17.4364M34.4542 15.125H34.9165M16.1924 25.5269C16.1924 27.9664 20.0901 29.2255 21.9714 29.2255C23.0035 29.2255 24.4901 29.4385 25.5543 29.6749C26.7697 29.945 28.3486 29.6878 29.5995 29.6878C30.8369 29.6878 32.2716 29.3041 33.4008 28.9815C34.442 28.684 35.6693 27.9603 36.7654 27.8385C39.4993 27.5347 39.628 24.5848 40.6951 22.9842M6.35268 19.0253C4.71048 19.0253 1 18.8155 1 21.2944C1 21.8044 1.23208 22.1678 1.34909 22.6358C1.45566 23.0621 1.80376 23.2472 2.13453 23.4762C2.52606 23.7473 3.04874 23.7525 3.48887 23.9126C3.80909 24.029 4.18822 24.029 4.53049 24.0289L4.54906 24.0289M50.2215 15.1857C51.5201 15.1857 52.9442 15.1247 54.2069 15.509C54.6532 15.6448 55.0678 15.9929 55.3414 16.3623C55.5998 16.7111 55.9197 16.9901 55.9782 17.458C56.0309 17.8801 55.9896 18.3131 55.8359 18.7057C55.467 19.6486 54.3461 20.1435 53.4764 20.4479C52.8335 20.6729 52.0623 20.6548 51.3851 20.6548" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </a>
          <div class="flex items-center gap-6 mt-4">
            {navLinks.map(link => {
              const isActive = pathname.startsWith(link.href);
              return (
                <a
                  href={link.href}
                  class:list={[
                    "transition-colors",
                    isActive ? "nav-link-active" : "nav-link"
                  ]}
                  aria-current={isActive ? "page" : undefined}
                >
                  {link.name}
                </a>
              );
            })}
          </div>
        </nav>
      </header>
    )}

    <main class="flex-1">
      <slot />
    </main>

    <footer class="mt-auto">
      <div class="max-w-2xl px-6 py-8">
        <div class="flex items-center justify-between gap-4">
          <!-- Social links (always visible) -->
          <div class="flex items-center gap-4">
            {socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:opacity-100 transition-colors text-sm"
                style="color: var(--text-tertiary);"
              >
                {link.name}
              </a>
            ))}
          </div>

          <!-- Mobile: theme toggle -->
          <div class="lg:hidden">
            <ThemeToggle />
          </div>
        </div>
      </div>
    </footer>
    <script is:inline>
      // Goofy mode - lazy loaded
      document.addEventListener('keydown', function(e) {
        if (e.shiftKey && e.key === 'G') {
          var on = localStorage.getItem('goofy') !== 'true';
          localStorage.setItem('goofy', on);
          console.log('goofy mode:' + (on ? 'ON' : 'OFF'));
          if (on && !window.__goofyInit) {
            import('/scripts/goofy.js').then(function(m) { m.initGoofy(); });
          }
        }
      });
      // If goofy is already on from a previous session, load immediately
      if (localStorage.getItem('goofy') === 'true' && !window.__goofyInit) {
        import('/scripts/goofy.js').then(function(m) { m.initGoofy(); });
      }

      // ASCII mode toggle (Shift+A)
      document.addEventListener('keydown', function(e) {
        if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
        if (e.shiftKey && e.key === 'A') {
          window.dispatchEvent(new CustomEvent('ascii-mode-toggle'));
        }
      });

      // Pastel link colors
      const pastels = [
        '#fca5a5', '#fdba74', '#fcd34d', '#bef264', '#86efac',
        '#5eead4', '#7dd3fc', '#a5b4fc', '#c4b5fd', '#f0abfc', '#fda4af'
      ];

      function assignColors() {
        document.querySelectorAll('.prose a').forEach(link => {
          const color = pastels[Math.floor(Math.random() * pastels.length)];
          link.style.setProperty('--link-color', color);

          link.addEventListener('mouseenter', () => {
            window.dispatchEvent(new CustomEvent('viz-color', { detail: color }));
          });
          link.addEventListener('mouseleave', () => {
            window.dispatchEvent(new CustomEvent('viz-color-reset'));
          });
        });
      }

      assignColors();
      document.addEventListener('astro:after-swap', assignColors);

      // Image lightbox
      (function() {
        function ensureLightbox() {
          let lightbox = document.getElementById('lightbox');
          if (!lightbox) {
            lightbox = document.createElement('div');
            lightbox.id = 'lightbox';
            lightbox.className = 'lightbox';
            lightbox.innerHTML = '<img src="" alt="" />';
            document.body.appendChild(lightbox);

            lightbox.addEventListener('click', () => {
              lightbox.classList.remove('active');
              document.body.style.overflow = '';
            });
          }
          return lightbox;
        }

        function openLightbox(src, alt) {
          const lightbox = ensureLightbox();
          const lightboxImg = lightbox.querySelector('img');
          lightboxImg.src = src;
          lightboxImg.alt = alt;
          lightbox.classList.add('active');
          document.body.style.overflow = 'hidden';
        }

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            const lightbox = document.getElementById('lightbox');
            if (lightbox) {
              lightbox.classList.remove('active');
              document.body.style.overflow = '';
            }
          }
        });

        function attachLightbox() {
          ensureLightbox();
          document.querySelectorAll('.prose img').forEach(img => {
            if (img.dataset.lightboxAttached) return;
            img.dataset.lightboxAttached = 'true';
            img.style.cursor = 'zoom-in';
            img.addEventListener('click', (e) => {
              e.preventDefault();
              e.stopPropagation();
              openLightbox(img.src, img.alt);
            });
          });
        }

        // Run on initial load and after navigation
        attachLightbox();
        document.addEventListener('astro:after-swap', attachLightbox);
        document.addEventListener('astro:page-load', attachLightbox);
      })();

      // Image link hover preview + rich link preview
      (function() {
        function ensureImagePreview() {
          let preview = document.getElementById('image-preview');
          if (!preview) {
            preview = document.createElement('div');
            preview.id = 'image-preview';
            preview.className = 'image-preview';
            preview.innerHTML = '<img src="" alt="" />';
            document.body.appendChild(preview);
          }
          return preview;
        }

        function ensureLinkPreview() {
          let card = document.getElementById('link-preview');
          if (!card) {
            card = document.createElement('div');
            card.id = 'link-preview';
            card.className = 'link-preview';
            const inner = document.createElement('div');
            inner.className = 'link-preview-inner';
            card.appendChild(inner);
            document.body.appendChild(card);
          }
          return card;
        }

        const imageExtensions = /\.(png|jpg|jpeg|gif|webp|svg)$/i;
        const ogCache = new Map();
        let currentAbortController = null;
        let lastMouseEvt = null;

        function showImagePreview(e, src) {
          const preview = ensureImagePreview();
          preview.querySelector('img').src = src;
          preview.classList.add('active');
          updatePosition(e, 'image-preview');
        }

        function hideImagePreview() {
          const preview = document.getElementById('image-preview');
          if (preview) preview.classList.remove('active');
        }

        function buildContentHTML(data) {
          let html = '';
          if (data.ogImage) {
            html += `<img class="link-preview-image" src="${data.ogImage}" alt="" onerror="this.style.display='none'" />`;
          }
          html += '<div class="link-preview-body">';
          if (data.ogTitle) html += `<div class="link-preview-title">${data.ogTitle}</div>`;
          if (data.domain) html += `<div class="link-preview-domain">${data.domain}</div>`;
          html += '</div>';
          return html;
        }

        const SHIMMER_HTML = '<div class="link-preview-shimmer"><div class="link-preview-shimmer-line"></div><div class="link-preview-shimmer-line"></div></div>';
        const BASE_TRANSITION = 'opacity 0.15s ease, visibility 0.15s ease';

        // Set content with optional morph animation (height + opacity crossfade)
        function setContent(html, morph) {
          const card = ensureLinkPreview();
          const inner = card.querySelector('.link-preview-inner');

          if (!morph || !card.classList.contains('active')) {
            card.style.transition = BASE_TRANSITION;
            card.style.height = '';
            inner.innerHTML = html;
            inner.style.opacity = '1';
            return;
          }

          const fromH = card.offsetHeight;
          inner.style.opacity = '0';

          setTimeout(() => {
            inner.innerHTML = html;

            // Measure natural height with transition disabled
            card.style.transition = BASE_TRANSITION;
            card.style.height = 'auto';
            const toH = card.offsetHeight;

            // Snap to fromH without animation, then animate to toH
            card.style.height = fromH + 'px';
            card.offsetHeight; // force reflow
            card.style.transition = BASE_TRANSITION + ', height 0.22s ease';
            card.style.height = toH + 'px';
            inner.style.opacity = '1';

            // After animation settles, reset to auto so card reflows on position updates
            setTimeout(() => {
              card.style.transition = BASE_TRANSITION;
              card.style.height = '';
              if (lastMouseEvt) updatePosition(lastMouseEvt, 'link-preview');
            }, 230);
          }, 100);
        }

        function showShimmer(e) {
          lastMouseEvt = e;
          const card = ensureLinkPreview();
          setContent(SHIMMER_HTML, card.classList.contains('active'));
          card.classList.add('active');
          updatePosition(e, 'link-preview');
        }

        function showContent(data) {
          if (!data || (!data.ogTitle && !data.ogImage)) {
            hideLinkPreview();
            return;
          }
          setContent(buildContentHTML(data), true);
        }

        function hideLinkPreview() {
          if (currentAbortController) { currentAbortController.abort(); currentAbortController = null; }
          const card = document.getElementById('link-preview');
          if (card) {
            card.classList.remove('active');
            card.style.height = '';
          }
          lastMouseEvt = null;
        }

        function updatePosition(e, id) {
          const el = document.getElementById(id);
          if (!el) return;
          const padding = 16;
          let x = e.clientX + padding;
          let y = e.clientY + padding;
          const rect = el.getBoundingClientRect();
          if (x + rect.width > window.innerWidth) x = e.clientX - rect.width - padding;
          if (y + rect.height > window.innerHeight) y = e.clientY - rect.height - padding;
          el.style.left = x + 'px';
          el.style.top = y + 'px';
        }

        // Returns an absolute URL for the preview API (handles internal + external links)
        function getPreviewUrl(href) {
          if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return null;
          if (href.startsWith('/')) return window.location.origin + href;
          if (href.startsWith('http://') || href.startsWith('https://')) return href;
          return null;
        }

        async function fetchOgData(href, e) {
          const url = getPreviewUrl(href);
          if (!url) return;

          if (ogCache.has(url)) {
            const cached = ogCache.get(url);
            if (cached) {
              const card = ensureLinkPreview();
              setContent(buildContentHTML(cached), false);
              card.classList.add('active');
              updatePosition(e, 'link-preview');
            }
            return;
          }

          if (currentAbortController) currentAbortController.abort();
          currentAbortController = new AbortController();

          // Delay shimmer so fast responses (empty/error) never flash it
          let resolved = false;
          const shimmerTimer = setTimeout(() => {
            if (!resolved) showShimmer(e);
          }, 150);

          try {
            const res = await fetch(`/api/link-preview.json?url=${encodeURIComponent(url)}`, {
              signal: currentAbortController.signal,
            });
            const data = await res.json();
            const hasContent = data && (data.ogTitle || data.ogImage);
            resolved = true;
            clearTimeout(shimmerTimer);
            ogCache.set(url, hasContent ? data : null);
            if (hasContent) {
              showContent(data);
            } else {
              hideLinkPreview();
            }
          } catch (err) {
            resolved = true;
            clearTimeout(shimmerTimer);
            if (err.name !== 'AbortError') {
              ogCache.set(url, null);
              hideLinkPreview();
            }
          }
        }

        function attachPreviews() {
          ensureImagePreview();
          ensureLinkPreview();
          document.querySelectorAll('.prose a').forEach(link => {
            if (link.dataset.previewAttached) return;
            link.dataset.previewAttached = 'true';

            // Seed cache from inline data-og-* attributes (for sites that block scraping)
            const href = link.getAttribute('href') || '';
            const fullUrl = getPreviewUrl(href);
            if (fullUrl && (link.dataset.ogTitle || link.dataset.ogImage) && !ogCache.has(fullUrl)) {
              ogCache.set(fullUrl, {
                ogTitle: link.dataset.ogTitle || '',
                ogImage: link.dataset.ogImage || '',
                domain: link.dataset.ogDomain || new URL(fullUrl).hostname.replace(/^www\./, ''),
              });
            }

            const previewUrl = link.dataset.preview || (imageExtensions.test(href) ? href : null);

            if (previewUrl) {
              link.addEventListener('mouseenter', (e) => showImagePreview(e, previewUrl));
              link.addEventListener('mousemove', (e) => updatePosition(e, 'image-preview'));
              link.addEventListener('mouseleave', hideImagePreview);
            } else if (getPreviewUrl(href)) {
              link.addEventListener('mouseenter', (e) => fetchOgData(href, e));
              link.addEventListener('mousemove', (e) => { lastMouseEvt = e; updatePosition(e, 'link-preview'); });
              link.addEventListener('mouseleave', hideLinkPreview);
            }
          });
        }

        // Run on initial load and after navigation
        attachPreviews();
        document.addEventListener('astro:after-swap', attachPreviews);
        document.addEventListener('astro:page-load', attachPreviews);
      })();

      // Konami code - lazy loaded
      (function() {
        if (window.__konamiInit) return;
        window.__konamiInit = true;
        var SEQ = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','KeyB','KeyA'];
        var buf = [];
        document.addEventListener('keydown', function(e) {
          if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
          buf.push(e.code);
          if (buf.length > SEQ.length * 2) buf = buf.slice(-SEQ.length);
          if (buf.length >= SEQ.length && buf.slice(-SEQ.length).every(function(k, i) { return k === SEQ[i]; })) {
            buf = [];
            import('/scripts/konami.js').then(function(m) { m.initKonami(); });
          }
        });
      })();
    </script>
  </body>
</html>
